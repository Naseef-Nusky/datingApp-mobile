# Mobile app — production build (no trailing slash)
VITE_API_URL=https://api.mobile.vantagedating.com

# Optional: override Socket.IO host (defaults to VITE_API_URL on native)
# VITE_SOCKET_URL=https://api.yourdomain.com

# Local simulator against Mac backend:
# VITE_API_URL=http://YOUR_MAC_LAN_IP:5000

# After changing env, rebuild and sync:
#   npm run cap:sync:ios
