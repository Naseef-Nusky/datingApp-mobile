{
  "name": "dating-app-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Vantage Dating — iOS/Android mobile app (Capacitor)",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/ensure-apple-sign-in-capacitor8-spm.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "sync:ios-app-icon": "sips -z 1024 1024 public/apple-touch-icon.png --out ios/App/App/Assets.xcassets/AppIcon.appiconset/AppIcon-512@2x.png",
    "cap:sync": "npm run build && npx cap sync",
    "cap:sync:ios": "npm run sync:ios-app-icon && npm run build && npx cap sync ios",
    "cap:ios": "npx cap open ios",
    "cap:run:ios": "npm run sync:ios-app-icon && npm run build && npx cap sync ios && npx cap run ios"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "agora-chat": "^1.3.1",
    "agora-rtc-sdk-ng": "^4.23.0",
    "agora-rtm-sdk": "^2.2.3-1",
    "agora-token": "^2.0.5",
    "axios": "^1.6.2",
    "heic2any": "^0.0.4",
    "i18next": "^25.8.14",
    "lucide-react": "^0.563.0",
    "react": "^18.2.0",
    "react-country-flag": "^3.1.0",
    "react-dom": "^18.2.0",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^16.5.6",
    "react-icons": "^4.12.0",
    "react-router-dom": "^6.20.1",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0"
  }
}
