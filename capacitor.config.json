{
  "appId": "com.vantagedating.app",
  "appName": "Vantage Dating",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "hostname": "localhost",
    "allowNavigation": [
      "checkout.stripe.com",
      "*.stripe.com",
      "js.stripe.com",
      "hooks.stripe.com",
      "m.stripe.com",
      "localhost",
      "127.0.0.1",
      "api.vantagedating.com",
      "*.vantagedating.com"
    ]
  },
  "ios": {
    "contentInset": "never",
    "scrollEnabled": true
  },
  "plugins": {
    "CapacitorHttp": {
      "enabled": true
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0066cc",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "overlaysWebView": true
    }
  }
}
