# Backend API URL (no trailing slash)
# Production: https://api.vantagedating.com
# VITE_API_URL=https://api.vantagedating.com

# Vite dev: proxy /api → backend. Mobile app rewrites /api/* to /api/mobile/* automatically.
# Must match datingApp-backend PORT (use 5001 on Mac if AirPlay blocks 5000).
VITE_DEV_PROXY_API=http://localhost:5001

# Optional socket override (defaults to same host as API)
# VITE_SOCKET_URL=
