# Backend API URL (no trailing slash)
# Local: use empty or http://localhost:5000 (dev server can proxy /api)
# Production: set to your API URL, e.g. https://api.yourdomain.com
VITE_API_URL=http://localhost:5000

# Vite-only: where to proxy /api during `npm run dev` (default http://localhost:5000). Set if your API uses another port.
# VITE_DEV_PROXY_API=http://localhost:5000

# Capacitor iOS/Android: axios uses this at build time — set before `npm run cap:sync`
# iOS Simulator: http://localhost:PORT hits the SIMULATOR, not your Mac. Use either:
#   - Production: VITE_API_URL=https://api.yourdomain.com
#   - Dev from simulator: VITE_API_URL=http://YOUR_MAC_LAN_IP:5000 (backend must listen on 0.0.0.0)
# Empty VITE_API_URL breaks API calls in the native shell (no Vite proxy).

# Magic login from the iOS app: the API emails a com.vantagedating.app:// link (configure IOS_APP_LOGIN_SCHEME on the backend; URL scheme is in ios/App/App/Info.plist).

# Sign in with Apple (native iOS only in UI). Defaults: bundle id com.vantagedating.app, redirect = site origin.
# VITE_APPLE_NATIVE_CLIENT_ID=com.vantagedating.app
# VITE_APPLE_REDIRECT_URI=https://your-web-origin/

# Google Analytics 4 — set in .env.local or .env for dev; use .env.production for build
VITE_GA_MEASUREMENT_ID=G-NHY9GW6GKG

# Public site URL (no trailing slash) — used for canonical, Open Graph, and JSON-LD
# VITE_SITE_URL=https://app.yourdomain.com

# Optional: full URL to share image for social previews (overrides default /og-image.png)
# VITE_OG_IMAGE_URL=https://app.yourdomain.com/og-image.png
